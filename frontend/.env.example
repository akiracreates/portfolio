# Public site URL (used in spin reward emails for commissions link)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Spin wheel: persistence (Upstash Redis) ---
# Create a free Redis database at https://upstash.com — REST URL + token.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Spin wheel: email (Resend) ---
# https://resend.com — verify a sending domain for production (onboarding@resend.dev only sends to your own signup email).
# On Vercel: add RESEND_API_KEY + EMAIL_FROM under Project → Settings → Environment Variables for Production (and Preview if needed), then redeploy.
#
# Local testing: if EMAIL_FROM is onboarding@resend.dev, Resend only delivers the *user* copy to the address on your Resend account.
# Use that same address in the spin form, or verify a domain and send from noreply@yourdomain.com to any recipient.
RESEND_API_KEY=
# Must be a verified sender in Resend, e.g. "Akira <onboarding@resend.dev>" or your domain.
EMAIL_FROM=
# Where spin wheel admin notifications go (defaults to akiracreates.comms@gmail.com if unset).
ADMIN_SPIN_EMAIL=akiracreates.comms@gmail.com
# Commission / contact form submissions (falls back to ADMIN_SPIN_EMAIL, then same default).
ADMIN_COMMISSION_EMAIL=akiracreates.comms@gmail.com
